# Environment variables for local development
# Copy this to .env and fill in your values

# --- Gateway ---
ZENGATE_PORT=8080
ZENGATE_ENV=development
ZENGATE_UPSTREAM_URL=http://localhost:9090
ZENGATE_VERSION=0.1.0

# --- Timeouts ---
ZENGATE_READ_TIMEOUT=15s
ZENGATE_WRITE_TIMEOUT=15s
ZENGATE_IDLE_TIMEOUT=60s
ZENGATE_SHUTDOWN_TIMEOUT=30s
ZENGATE_PROXY_TIMEOUT=10s

# --- CORS ---
ZENGATE_CORS_ORIGINS=*

# --- Rate Limiting (Phase 2) ---
ZENGATE_RATELIMIT_ENABLED=false
ZENGATE_REDIS_URL=redis://localhost:6379

# --- etcd (Phase 2) ---
ZENGATE_ETCD_ENDPOINTS=localhost:2379

# --- AI Brain (Phase 3) ---
ZENGATE_AI_ENABLED=false

# --- LLM Keys ---
# DeepSeek V4 Flash Free (via OpenCode Zen)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://opencode.ai/zen/v1

# Gemini API Free Tier
GEMINI_API_KEY=
